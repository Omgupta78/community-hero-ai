{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "community-hero-ai",
  "compatibility_date": "2026-04-26",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "community-hero-ai-production",
      "database_id": "local-placeholder-id"
    }
  ]
}
